<form col="6">
    <label name="name"/>
    <field name="name"/>
    <label name="method"/>
    <field name="method"/>
    <group id="checkboxes" colspan="2" col="-1">
        <label name="template"/>
        <field name="template"/>
        <label name="has_header"/>
        <field name="has_header"/>
        <label name="use_header"/>
        <field name="use_header"/>
    </group>
    <label name="data_source"/>
    <field name="data_source"/>
    <group id="data" colspan="3" col="3">
        <field name="binary_data"/>
        <field name="binary_file_name" invisible="1"/>
        <field name="url_data" widget="url" colspan="3"/>
        <field name="sql_data"/>
    </group>
    <group id="sql" colspan="6" col="6">
        <label name="sql_source"/>
        <field name="sql_source"/>
        <label name="server"/>
        <field name="server"/>
        <label name="database"/>
        <field name="database"/>
        <label name="schema"/>
        <field name="schema"/>
        <label name="user"/>
        <field name="user"/>
        <label name="password"/>
        <field name="password" widget="password"/>
    </group>
    <group id="buttons" col="-1" colspan="3">
        <button name="detect"/>
        <button name="import_"/>
        <button name="check_connection"/>
    </group>
    <label name="where"/>
    <field name="where" colspan="5"/>
    <separator name="text_data" colspan="6"/>
    <field name="text_data" colspan="6" height="200"/>
    <notebook colspan="6">
        <page string="Importer columns" id="columns">
            <field name="columns" colspan="6" height="500"/>
        </page>
        <page string="File columns" id="reverse_columns">
            <field name="reverse_columns" colspan="6" height="500"/>
        </page>
    </notebook>
</form>