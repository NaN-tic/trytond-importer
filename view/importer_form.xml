<form col="6">
    <label name="name"/>
    <field name="name"/>
    <label name="method"/>
    <field name="method"/>
    <group id="checkboxes" colspan="2" col="-1">
        <label name="template"/>
        <field name="template"/>
        <label name="has_header"/>
        <field name="has_header"/>
        <label name="use_header"/>
        <field name="use_header"/>
    </group>
    <group id="source" colspan="2" col="4">
        <label name="data_source"/>
        <field name="data_source"/>
        <label name="language"/>
        <field name="language"/>
    </group>
    <group id="buttons" col="-1" colspan="4">
        <button name="update_columns"/>
        <button name="update_source_columns"/>
        <button name="detect"/>
        <button name="import_"/>
        <button name="check_connection"/>
    </group>
    <group id="data" colspan="6" col="6">
        <label name="url_data"/>
        <field name="url_data" widget="url" colspan="5"/>
        <label name="binary_data"/>
        <field name="binary_data"/>
        <field name="binary_file_name" colspan="4"/>
        <label name="sql_data"/>
        <field name="sql_data"/>
    </group>
    <group id="sql" colspan="6" col="6">
        <label name="sql_source"/>
        <field name="sql_source"/>
        <label name="server"/>
        <field name="server"/>
        <label name="database"/>
        <field name="database"/>
        <label name="schema"/>
        <field name="schema"/>
        <label name="user"/>
        <field name="user"/>
        <label name="password"/>
        <field name="password" widget="password"/>
        <label name="where"/>
        <field name="where" colspan="5"/>
    </group>
    <notebook colspan="6">
        <page name="columns">
            <field name="columns" colspan="4" height="500"/>
        </page>
        <page name="source_columns">
            <field name="source_columns" colspan="4" height="500"/>
        </page>
        <page name="text_data">
            <field name="text_data" height="500" colspan="4"/>
        </page>
        <page name="errors" col="10">
            <label name="on_error"/>
            <field name="on_error"/>
            <label name="elapsed"/>
            <field name="elapsed" xexpand="0" xfill="0"/>
            <group id="checkboxes" colspan="5" col="-1">
                <label name="log_success"/>
                <field name="log_success"/>
                <label name="use_subtransactions"/>
                <field name="use_subtransactions"/>
                <label name="commit_chunks"/>
                <field name="commit_chunks"/>
            </group>
            <button name="clean_log" colspan="1"/>
            <newline/>
            <label name="sample_size"/>
            <field name="sample_size"/>
            <label name="sample_offset"/>
            <field name="sample_offset"/>
            <button name="import_sample" colspan="2"/>
            <newline/>
            <field name="errors" height="400" colspan="10"/>
        </page>
        <page name="deletes">
            <field name="deletes" height="500" colspan="4"/>
            <button name="clean_deletes"/>
            <button name="delete_imported"/>
        </page>
    </notebook>
</form>
