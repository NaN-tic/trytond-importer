        <record model="ir.ui.view" id="import_ask_view_form">
            <field name="model">importer.import.ask</field>
            <field name="type">form</field>
            <field name="name">import_ask</field>
        </record>
        <record model="ir.action.wizard" id="act_import_wizard">
            <field name="name">Import</field>
            <field name="wiz_name">importer.import</field>
        </record>
        <record model="ir.action.wizard" id="act_ask_and_import_wizard">
            <field name="name">Import</field>
            <field name="wiz_name">importer.ask_and_import</field>
        </record>
        <record model="ir.action.act_window" id="act_import_open">
            <field name="name">Imported Records</field>
            <field name="res_model">importer</field>
        </record>
        <menuitem parent="menu_importer" action="act_ask_and_import_wizard" id="menu_import_wizard" sequence="30"/>

         <record model="ir.action.report" id="report_excel_template">
            <field name="name">Excel Template</field>
            <field name="model">importer</field>
            <field name="report_name">importer.excel.template</field>
            <field name="extension">xlsx</field>
            <field name="template_extension">xml</field>
        </record>
        <record model="ir.action.keyword" id="report_excel_template_keyword">
            <field name="keyword">form_print</field>
            <field name="model">importer,-1</field>
            <field name="action" ref="report_excel_template"/>
        </record>
    </data>
</tryton>
