<tryton>
    <data>
        <record model="res.group" id="group_importer">
            <field name="name">Importer</field>
        </record>
        <record model="res.user-res.group" id="user_admin_group_importer">
            <field name="user" ref="res.user_admin"/>
            <field name="group" ref="group_importer"/>
        </record>

        <record model="ir.ui.icon" id="detect_icon">
            <field name="name">importer-detect</field>
            <field name="path">icons/radar.svg</field>
        </record>
        <record model="ir.ui.icon" id="upload_icon">
            <field name="name">importer-upload</field>
            <field name="path">icons/upload.svg</field>
        </record>

        <menuitem name="Importer" id="menu_importer" icon="importer-upload" sequence="90"/>
        <record model="ir.ui.menu-res.group" id="menu_importer_group_importer">
            <field name="menu" ref="menu_importer"/>
            <field name="group" ref="group_importer"/>
        </record>

        <record model="ir.ui.view" id="importer_view_form">
            <field name="model">importer</field>
            <field name="type">form</field>
            <field name="name">importer_form</field>
        </record>
        <record model="ir.ui.view" id="importer_view_tree">
            <field name="model">importer</field>
            <field name="type">tree</field>
            <field name="name">importer_list</field>
        </record>
        <record model="ir.action.act_window" id="act_importer">
            <field name="name">Importers</field>
            <field name="res_model">importer</field>
        </record>
        <record model="ir.action.act_window.view" id="act_importer_form_view1">
            <field name="sequence" eval="10"/>
            <field name="view" ref="importer_view_tree"/>
            <field name="act_window" ref="act_importer"/>
        </record>
        <record model="ir.action.act_window.view" id="act_importer_form_view2">
            <field name="sequence" eval="20"/>
            <field name="view" ref="importer_view_form"/>
            <field name="act_window" ref="act_importer"/>
        </record>
        <menuitem parent="menu_importer" action="act_importer" id="menu_importers" sequence="10"/>

        <record model="ir.model.access" id="access_importer">
            <field name="model">importer</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_delete" eval="False"/>
        </record>
        <record model="ir.model.access" id="access_importer_importer">
            <field name="model">importer</field>
            <field name="group" ref="group_importer"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="True"/>
        </record>

        <record model="ir.model.button" id="importer_update_columns_button">
            <field name="name">update_columns</field>
            <field name="string">Update Columns</field>
            <field name="model">importer</field>
        </record>
        <record model="ir.model.button-res.group" id="importer_update_columns_button_group_importer">
            <field name="button" ref="importer_update_columns_button"/>
            <field name="group" ref="group_importer"/>
        </record>
        <record model="ir.model.button" id="importer_clean_errors_button">
            <field name="name">clean_errors</field>
            <field name="string">Clean Errors</field>
            <field name="model">importer</field>
        </record>
        <record model="ir.model.button-res.group" id="importer_clean_errors_button_group_importer">
            <field name="button" ref="importer_clean_errors_button"/>
            <field name="group" ref="group_importer"/>
        </record>
        <record model="ir.model.button" id="importer_export_button">
            <field name="name">export</field>
            <field name="string">Export</field>
            <field name="model">importer</field>
        </record>
        <record model="ir.model.button-res.group" id="importer_export_button_group_importer">
            <field name="button" ref="importer_export_button"/>
            <field name="group" ref="group_importer"/>
        </record>
        <record model="ir.model.button" id="importer_detect_button">
            <field name="name">detect</field>
            <field name="string">Detect</field>
            <field name="model">importer</field>
        </record>
        <record model="ir.model.button-res.group" id="importer_detect_button_group_importer">
            <field name="button" ref="importer_detect_button"/>
            <field name="group" ref="group_importer"/>
        </record>
        <record model="ir.model.button" id="importer_import_button">
            <field name="name">import_</field>
            <field name="string">Import</field>
            <field name="model">importer</field>
        </record>
        <record model="ir.model.button-res.group" id="importer_import_button_group_importer">
            <field name="button" ref="importer_import_button"/>
            <field name="group" ref="group_importer"/>
        </record>

        <record model="ir.model.button" id="importer_check_connection_button">
            <field name="name">check_connection</field>
            <field name="string">Check Connection</field>
            <field name="model">importer</field>
        </record>

        <record model="ir.model.button-res.group" id="importer_check_connection_button_group_importer">
            <field name="button" ref="importer_check_connection_button"/>
            <field name="group" ref="group_importer"/>
        </record>

        <record model="ir.ui.view" id="importer_column_view_form">
            <field name="model">importer.column</field>
            <field name="type">form</field>
            <field name="name">column_form</field>
        </record>
        <record model="ir.ui.view" id="importer_column_view_tree">
            <field name="model">importer.column</field>
            <field name="type">tree</field>
            <field name="name">column_list</field>
        </record>
        <record model="ir.ui.view" id="importer_reverse_column_view_list">
            <field name="model">importer.reverse_column</field>
            <field name="type">tree</field>
            <field name="name">importer_reverse_column_list</field>
        </record>
        <record model="ir.ui.view" id="importer_reverse_column_view_form">
            <field name="model">importer.reverse_column</field>
            <field name="type">form</field>
            <field name="name">importer_reverse_column_form</field>
        </record>
        <record model="ir.model.access" id="access_importer_column">
            <field name="model">importer.column</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_delete" eval="False"/>
        </record>
        <record model="ir.model.access" id="access_importer_column_importer">
            <field name="model">importer.column</field>
            <field name="group" ref="group_importer"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="True"/>
        </record>
        <record model="ir.model.access" id="access_importer_reverse_column">
            <field name="model">importer.reverse_column</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_delete" eval="False"/>
        </record>
        <record model="ir.model.access" id="access_importer_reverse_column_importer">
            <field name="model">importer.reverse_column</field>
            <field name="group" ref="group_importer"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="True"/>
        </record>

        <record model="ir.ui.view" id="importer_source_column_view_list">
            <field name="model">importer.source_column</field>
            <field name="type">tree</field>
            <field name="name">source_column_list</field>
        </record>
        <record model="ir.ui.view" id="importer_source_column_view_form">
            <field name="model">importer.source_column</field>
            <field name="type">form</field>
            <field name="name">source_column_form</field>
        </record>
        <record model="ir.model.access" id="access_importer_source_column">
            <field name="model">importer.source_column</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_delete" eval="False"/>
        </record>
        <record model="ir.model.access" id="access_importer_source_column_importer">
            <field name="model">importer.source_column</field>
            <field name="group" ref="group_importer"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="True"/>
        </record>

        <record model="ir.ui.view" id="importer_error_view_list">
            <field name="model">importer.error</field>
            <field name="type">tree</field>
            <field name="name">importer_error_list</field>
        </record>
        <record model="ir.ui.view" id="importer_error_view_form">
            <field name="model">importer.error</field>
            <field name="type">form</field>
            <field name="name">importer_error_form</field>
        </record>
        <record model="ir.model.access" id="access_importer_error">
            <field name="model">importer.error</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_delete" eval="False"/>
        </record>
        <record model="ir.model.access" id="access_importer_error_importer">
            <field name="model">importer.error</field>
            <field name="group" ref="group_importer"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
