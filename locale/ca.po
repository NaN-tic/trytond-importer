msgctxt "model:ir.message,text:account_not_found"
msgid "Account %(account)s not found."
msgstr "No s'ha trobat el compte %(account)s."

msgctxt "model:ir.message,text:change_method_warning"
msgid ""
"Changing the format on importer \"%(name)s\" may cause your settings to be "
"lost. Are you sure to proceed?"
msgstr ""
"Si canvieu el format de l'importador \"%(name)s\", pot ser que es perdi la "
"vostra configuració. Esteu segur de continuar?"

msgctxt "model:ir.message,text:invalid_column_name"
msgid ""
"Name \"%(name)s\" is not valid for column \"%(column)s\" in importer "
"\"%(importer)s\"."
msgstr ""
"El nom \"%(name)s\" no és vàlid per a la columna \"%(column)s\" de "
"l'importador \"%(importer)s\"."

msgctxt "model:ir.message,text:invalid_index"
msgid ""
"Column \"%(column)s\" does not exist importing data with importer "
"\"%(importer)s\"."
msgstr ""
"La columna \"%(column)s\" no existeix important dades amb l'importador "
"\"%(importer)s\"."

msgctxt "model:ir.message,text:msg_company_not_found"
msgid "Company %(company)s not found."
msgstr "No s'ha trobat l'empresa %(company)s."

msgctxt "model:ir.message,text:msg_deletes_disable"
msgid "Deletion of records is disabled."
msgstr "La supressió de registres està desactivada."

msgctxt "model:ir.message,text:msg_group_not_found"
msgid "Group with name \"%(name)s\" not found."
msgstr "No s'ha trobat el grup amb el nom \"%(name)s\"."

msgctxt "model:ir.message,text:msg_invalid_connection"
msgid "Could not establish connection using importer \"%(importer)s\"."
msgstr "No s'ha pogut establir la connexió amb l'importador \"%(importer)s\"."

msgctxt "model:ir.message,text:msg_invalid_invoice_type"
msgid "Invoice type must be 'out' or 'in' but \"%(type)s\" was found."
msgstr ""
"El tipus de factura ha de ser \"fora\" o \"dins\", però s'ha trobat \""
"%(type)s\"."

msgctxt "model:ir.message,text:msg_role_not_found"
msgid "Role with name \"%(name)s\" not found."
msgstr "No s'ha trobat el rol amb el nom \"%(name)s\"."

msgctxt "model:ir.message,text:msg_sequence_type_not_found"
msgid "Sequence Type \"%(type)s\" not found."
msgstr "No s'ha trobat el tipus de seqüència \"%(type)s\"."

msgctxt "model:ir.message,text:msg_sequence_type_required"
msgid "Sequence Type is required"
msgstr "El tipus de seqüència és obligatori"

msgctxt "model:ir.message,text:msg_subdivision_not_found"
msgid "Subdivision \"%(subdivision)s\" not found in country \"%(country)s\"."
msgstr ""
"La subdivisió \"%(subdivision)s\" no s'ha trobat al país \"%(country)s\"."

msgctxt "model:ir.message,text:msg_subdivision_type_not_allowed"
msgid ""
"Subdivision type \"%(type)s\" of subdivision \"%(subdivision)s\" not allowed."
msgstr ""
"No es permet el tipus de subdivisió \"%(type)s\" de la subdivisió "
"\"%(subdivision)s\"."

msgctxt "model:ir.message,text:msg_successful_connection"
msgid "Successful connection using importer \"%(importer)s\"."
msgstr "Connexió correcta mitjançant l'importador \"%(importer)s\"."

msgctxt "model:ir.message,text:no_records_imported"
msgid "No records where imported using importer \"%(importer)s\"."
msgstr "No s'ha importat cap registre amb l'importador \"%(importer)s\"."

msgctxt "model:ir.message,text:party_not_found"
msgid "Party \"%(party)s\" not found."
msgstr "No s'ha trobat el tercer \"%(party)s\"."

msgctxt "model:ir.message,text:party_required_for_account"
msgid ""
"Account \"%(account)s\" requires a party but no party was supplied in move "
"\"%(move)s\"."
msgstr ""
"El compte \"%(account)s\" requereix un tercer, però no s'ha proporcionat cap"
" tercer al moviment \"%(move)s\"."

msgctxt "model:ir.message,text:product_category_not_found"
msgid "Product category \"%(category)s\" not found."
msgstr "No s'ha trobat la categoria de producte \"%(category)s\"."

msgctxt "model:ir.message,text:single_party_error"
msgid "There must be one and only one party with \"%(party)s\"."
msgstr "Hi ha d'haver un i només un tercer amb \"%(party)s\"."

msgctxt "model:ir.message,text:single_product_error"
msgid "There must be one and only one product with \"%(product)s\"."
msgstr "Hi ha d'haver un i només un producte amb \"%(product)s\"."

msgctxt "model:ir.message,text:value_not_in_selection"
msgid "Could not find this value in the field selection \"%(field)%\""
msgstr "No s'ha pogut trobar aquest valor a la selecció de camp \"%(field)%\""

