msgctxt "model:ir.message,text:change_method_warning"
msgid ""
"Changing the format on importer \"%(name)s\" may cause your settings to be "
"lost. Are you sure to proceed?"
msgstr ""
"Si es canvia el format de l'importador \"%(name)s\" pot perdre algunes "
"configuracions. Esteu segurs de continuar?"

msgctxt "model:ir.message,text:farm_not_found"
msgid "Farm %(farm)s not found."
msgstr "No s'ha trobat la granja %(farm)s."

msgctxt "model:ir.message,text:invalid_column_name"
msgid ""
"Name \"%(name)s\" is not valid for column \"%(column)s\" in importer "
"\"%(importer)s\"."
msgstr ""
"Nom \"%(name)s\" no és vàlid per la columna \"%(column)s\" a l'importador "
"\"%(importer)s\"."

msgctxt "model:ir.message,text:invalid_index"
msgid ""
"Column \"%(column)s\" does not exist importing data with importer "
"\"%(importer)s\"."
msgstr ""
"La columna \"%(column)s\" no existeix quan s'importa dades amb "
"l'importador\"%(importer)s\"."

msgctxt "model:ir.message,text:location_not_found"
msgid "Location %(location)s not found."
msgstr "La ubicació %(location)s no s'ha trobat."

msgctxt "model:ir.message,text:no_period_for_date"
msgid "No period for date \"%(date)s\"."
msgstr "No s'ha definit el període per la data  \"%(date)s\"."

msgctxt "model:ir.message,text:no_records_imported"
msgid "No records where imported using importer \"%(importer)s\"."
msgstr "No s'han creat registres a partir de \"%(importer)s\"."

msgctxt "model:ir.message,text:party_required_for_account"
msgid ""
"Account \"%(account)s\" requires a party but no party was supplied in move "
"\"%(move)s\"."
msgstr ""
"El compte \"%(account)s\" requereix un tercer però no hi ha un tercer "
"informat a l'apunt  \"%(move)s\"."

msgctxt "model:ir.message,text:single_party_error"
msgid "There must be one and only one party with \"%(party)s\"."
msgstr "Només hi ha d'haver un i només un tercer amb \"%(party)s\"."

msgctxt "model:ir.message,text:single_product_error"
msgid "There must be one and only one product with \"%(product)s\"."
msgstr "Només hi ha d'haver un i només un producte amb \"%(product)s\"."

