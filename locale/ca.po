"Name \"%(name)s\" is not valid for column \"%(column)s\" in importer "
"\"%(importer)s\"."
msgstr ""
"El nom \"%(name)s\" no és vàlid per a la columna \"%(column)s\" de "
"l'importador \"%(importer)s\"."

#, python-format
msgctxt "model:ir.message,text:invalid_index"
msgid ""
"Column \"%(column)s\" does not exist importing data with importer "
"\"%(importer)s\"."
msgstr ""
"La columna \"%(column)s\" no existeix important dades amb l'importador "
"\"%(importer)s\"."

#, python-format
msgctxt "model:ir.message,text:location_not_found"
msgid "Location %(location)s not found."
msgstr "No s'ha trobat la ubicació %(location)s."

#, python-format
msgctxt "model:ir.message,text:msg_account_not_found"
msgid "Account %(account)s not found."
msgstr "No s'ha trobat el compte %(account)s."

#, python-format
msgctxt "model:ir.message,text:msg_asset_product_not_found"
msgid ""
"Asset product \"%(product)s\" does not exist on the database or it could not"
" be found."
msgstr ""
"El producte actiu \"%(product)s\" no existeix a la base de dades o no s'ha "
"pogut trobar."

#, python-format
msgctxt "model:ir.message,text:msg_carrier_party_not_found"
msgid "Party code %(party)s not found."
msgstr "No s'ha trobat el codi de festa %(party)s."

#, python-format
msgctxt "model:ir.message,text:msg_carrier_product_not_found"
msgid "Product code %(product)s not found."
msgstr "No s'ha trobat el codi de producte %(product)s."

#, python-format
msgctxt "model:ir.message,text:msg_chart_not_found"
msgid "Chart \"%(chart)s\" not found."
msgstr "No s'ha trobat el gràfic \"%(chart)s\"."

#, python-format
msgctxt "model:ir.message,text:msg_company_not_found"
msgid "Company %(company)s not found."
msgstr "No s'ha trobat l'empresa %(company)s."

#, python-format
msgctxt "model:ir.message,text:msg_currency_not_found"
msgid "Currency %(currency)s not found."
msgstr "No s'ha trobat la moneda %(currency)s."

msgctxt "model:ir.message,text:msg_deletes_disabled"
msgid "Deletion of records is disabled."
msgstr "La supressió de registres està desactivada."

#, python-format
msgctxt "model:ir.message,text:msg_employee_not_found"
msgid "Employee %(employee)s not found."
msgstr "No s'ha trobat l'empleat %(employee)s."

#, python-format
msgctxt "model:ir.message,text:msg_group_not_found"
msgid "Group with name \"%(name)s\" not found."
msgstr "No s'ha trobat el grup amb el nom \"%(name)s\"."

#, python-format
msgctxt "model:ir.message,text:msg_invalid_connection"
msgid "Could not establish connection using importer \"%(importer)s\"."
msgstr "No s'ha pogut establir la connexió amb l'importador \"%(importer)s\"."

#, python-format
msgctxt "model:ir.message,text:msg_invalid_invoice_type"
msgid "Invoice type must be 'out' or 'in' but \"%(type)s\" was found."
msgstr ""
"El tipus de factura ha de ser \"fora\" o \"dins\", però s'ha trobat \"%(type)s"
"\"."

#, python-format
msgctxt "model:ir.message,text:msg_invalid_value"
msgid ""
"Invalid value \"%(value)s\" for column \"%(column)s\" in row \"%(row)s\" impor"
"ting data with importer \"%(importer)s\":\n"
"\n"
"%(error)s."
msgstr ""
"Valor no vàlid \"%(value)s\" per a la columna \"%(column)s\" a la fila "
"\"%(row)s\" important dades amb l'importador \"%(importer)s\": %(error)s."

msgctxt "model:ir.message,text:msg_name_required"
msgid "Missing company name."
msgstr "Falta el nom de l'empresa."

#, python-format
msgctxt "model:ir.message,text:msg_product_attribute_incorrect_cast"
msgid ""
"Value %(value)s is incorrect for attribute %(attribute)s expected type "
"%(type)s, with product code %(code)s"
msgstr ""
"El valor %(value)s és incorrecte per a l'atribut %(attribute)s, tipus "
"esperat %(type)s, amb el codi de producte %(code)s."

#, python-format
msgctxt "model:ir.message,text:msg_product_attribute_not_found"
msgid ""
"Attribute %(attribute)s for product of code %(code)s could not be found."
msgstr ""
"No s'ha pogut trobar l'atribut %(attribute)s per al producte del codi "
"%(code)s."

#, python-format
msgctxt "model:ir.message,text:msg_product_attribute_selection_not_found"
msgid ""
"Attribute set %(set)s attribute %(attribute)s of type \"Selection\" has no "
"selection option value %(selection)s."
msgstr ""
"El conjunt d'atributs %(set)s de l'atribut %(attribute)s de tipus "
"\"Selecció\" no té cap valor d'opció de selecció %(selection)s."

#, python-format
msgctxt "model:ir.message,text:msg_product_attribute_set_not_found"
msgid "Attribute set %(set)s for product of code %(code)s could not be found."
msgstr ""
"No s'ha pogut trobar el conjunt d'atributs %(set)s per al producte del codi "
"%(code)s."

#, python-format
msgctxt "model:ir.message,text:msg_project_group_not_found"
msgid "Project group %(group)s not found."
msgstr "No s'ha trobat el grup de projectes %(group)s."

#, python-format
msgctxt "model:ir.message,text:msg_project_workflow_not_found"
msgid "Project workflow %(workflow)s not found."
msgstr "No s'ha trobat el flux de treball del projecte %(workflow)s."

#, python-format
msgctxt "model:ir.message,text:msg_role_not_found"
msgid "Role with name \"%(name)s\" not found."
msgstr "No s'ha trobat el rol amb el nom \"%(name)s\"."

#, python-format
msgctxt "model:ir.message,text:msg_sequence_type_not_found"
msgid "Sequence Type \"%(type)s\" not found."
msgstr "No s'ha trobat el tipus de seqüència \"%(type)s\"."

msgctxt "model:ir.message,text:msg_sequence_type_required"
msgid "Sequence Type is required"
msgstr "El tipus de seqüència és obligatori"

#, python-format
msgctxt "model:ir.message,text:msg_status_not_found"
msgid "Status %(status)s not found."
msgstr "No s'ha trobat l'estat %(status)s."

#, python-format
msgctxt "model:ir.message,text:msg_subdivision_not_found"
msgid "Subdivision \"%(subdivision)s\" not found in country \"%(country)s\"."
msgstr ""
"La subdivisió \"%(subdivision)s\" no s'ha trobat al país \"%(country)s\"."

#, python-format
msgctxt "model:ir.message,text:msg_subdivision_type_not_allowed"
msgid ""
"Subdivision type \"%(type)s\" of subdivision \"%(subdivision)s\" not allowed."
msgstr ""
"No es permet el tipus de subdivisió \"%(type)s\" de la subdivisió "
"\"%(subdivision)s\"."

#, python-format
msgctxt "model:ir.message,text:msg_successful_connection"
msgid "Successful connection using importer \"%(importer)s\"."
msgstr "Connexió correcta mitjançant l'importador \"%(importer)s\"."

#, python-format
msgctxt "model:ir.message,text:msg_supervisor_not_found"
msgid "Supervisor \"%(supervisor)s\" not found."
msgstr "No s'ha trobat el supervisor \"%(supervisor)s\"."

#, python-format
msgctxt "model:ir.message,text:no_records_imported"
msgid "No records where imported using importer \"%(importer)s\"."
msgstr "No s'ha importat cap registre amb l'importador \"%(importer)s\"."

#, python-format
msgctxt "model:ir.message,text:order_point_not_value"
msgid ""
"Order point not fount a value for Warehouse:  %(warehouse)s or Product "
"%(product)s ."
msgstr ""
"El punt de comanda no ha establert un valor per al Magatzem: %(warehouse)s o"
" el Producte %(product)s."

#, python-format
msgctxt "model:ir.message,text:order_point_type_not_supported"
msgid "Type %(type_)s not supported for orderpoint."
msgstr "El tipus %(type_)s no és compatible amb el punt de comanda."

#, python-format
msgctxt "model:ir.message,text:party_not_found"
msgid "Party \"%(party)s\" not found."
msgstr "No s'ha trobat el tercer \"%(party)s\"."

#, python-format
msgctxt "model:ir.message,text:party_required_for_account"
msgid ""
"Account \"%(account)s\" requires a party but no party was supplied in move "
"\"%(move)s\"."
msgstr ""
"El compte \"%(account)s\" requereix un tercer, però no s'ha proporcionat cap"
" tercer al moviment \"%(move)s\"."

msgctxt "model:ir.message,text:produced_animals_not_found"
msgid "No produced animals found."
msgstr "No s'han trobat animals reproduïts."

#, python-format
msgctxt "model:ir.message,text:product_category_not_found"
msgid "Product category \"%(category)s\" not found."
msgstr "No s'ha trobat la categoria de producte \"%(category)s\"."

#, python-format
msgctxt "model:ir.message,text:single_party_error"
msgid "There must be one and only one party with \"%(party)s\"."
msgstr "Hi ha d'haver un i només un tercer amb \"%(party)s\"."

#, python-format
msgctxt "model:ir.message,text:single_product_error"
msgid "There must be one and only one product with \"%(product)s\"."
msgstr "Hi ha d'haver un i només un producte amb \"%(product)s\"."

#, python-format
msgctxt "model:ir.message,text:stock_move_error"
msgid ""
"Coud not create move, could not find some info: from_location: "
"\"%(from_location)s\", to_location: \"%(to_location)s\", product: "
"\"%(product)s\"."
msgstr ""
"No s'ha pogut crear el trasllat, no s'ha pogut trobar informació: "
"from_location: \"%(from_location)s\", to_location: \"%(to_location)s\", "
"product: \"%(product)s\"."

#, python-format
msgctxt "model:ir.message,text:tag_not_found"
msgid "Can't find tag \"%(tag)s\"."
msgstr "No es pot trobar l'etiqueta \"%(tag)s\"."

#, python-format
msgctxt "model:ir.message,text:value_not_in_selection"
msgid "Could not find this value in the field selection \"%(field)%\""
msgstr "No s'ha pogut trobar aquest valor a la selecció de camp \"%(field)%\""

