msgid "Account %(account)s not found."
msgstr "Account %(account)s no encontrada."

msgctxt "model:ir.message,text:change_method_warning"
msgid ""
"Changing the format on importer \"%(name)s\" may cause your settings to be "
"lost. Are you sure to proceed?"
msgstr ""
"Cambiar el formato del importador \"%(name)s\" puede causar la pérdida de "
"las configuraciones. ¿Quieres proceeder?"

msgctxt "model:ir.message,text:invalid_column_name"
msgid ""
"Name \"%(name)s\" is not valid for column \"%(column)s\" in importer "
"\"%(importer)s\"."
msgstr ""
"El nombre \"%(name)s\" no es válido para la columna \"%(column)s\" del "
"importador \"%(importer)s\"."

msgctxt "model:ir.message,text:invalid_index"
msgid ""
"Column \"%(column)s\" does not exist importing data with importer "
"\"%(importer)s\"."
msgstr ""
" La columna \"%(column)s\" no existe importando datos con el importador "
"\"%(importer)s\"."

msgctxt "model:ir.message,text:msg_company_not_found"
msgid "Company %(company)s not found."
msgstr "Empresa %(company)s no encontrada."

msgctxt "model:ir.message,text:msg_group_not_found"
msgid "Group with name \"%(name)s\" not found."
msgstr "No se encontró el grupo con el nombre \"%(name)s\"."

msgctxt "model:ir.message,text:msg_invalid_connection"
msgid "Could not establish connection using importer \"%(importer)s\"."
msgstr ""
"No se pudo establecer la conexión utilizando el importador \"%(importer)s\"."

msgctxt "model:ir.message,text:msg_invalid_invoice_type"
msgid "Invoice type must be 'out' or 'in' but \"%(type)s\" was found."
msgstr ""
"El tipo de facutura debe ser \"out\" o \"in\" y se obtenido \"%(type)s\"."

msgctxt "model:ir.message,text:msg_role_not_found"
msgid "Role with name \"%(name)s\" not found."
msgstr "Rol con nombre \"%(name)s\" no encontrado."

