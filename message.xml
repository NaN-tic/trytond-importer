<tryton>
    <data>
        <record model="ir.message" id="invalid_index">
            <field name="text">Column "%(column)s" does not exist importing data with importer "%(importer)s".</field>
        </record>
        <record model="ir.message" id="msg_invalid_value">
            <field name="text">Invalid value "%(value)s" for column "%(column)s" in row "%(row)s" importing data with importer "%(importer)s":

%(error)s.</field>
        </record>
        <record model="ir.message" id="invalid_column_name">
            <field name="text">Name "%(name)s" is not valid for column "%(column)s" in importer "%(importer)s".</field>
        </record>
  	    <record model="ir.message" id="no_records_imported">
            <field name="text">No records where imported using importer "%(importer)s".</field>
  	    </record>
        <record model="ir.message" id="msg_invalid_connection">
            <field name="text">Could not establish connection using importer "%(importer)s".</field>
        </record>
        <record model="ir.message" id="msg_successful_connection">
            <field name="text">Successful connection using importer "%(importer)s".</field>
        </record>
        <record model="ir.message" id="single_party_error">
            <field name="text">There must be one and only one party with "%(party)s".</field>
        </record>
        <record model="ir.message" id="single_product_error">
            <field name="text">There must be one and only one product with "%(product)s".</field>
        </record>
        <record model="ir.message" id="product_category_not_found">
            <field name="text">Product category "%(category)s" not found.</field>
        </record>
        <record model="ir.message" id="change_method_warning">
            <field name="text">Changing the format on importer "%(name)s" may cause your settings to be lost. Are you sure to proceed?</field>
        </record>
        <record model="ir.message" id="msg_account_not_found">
            <field name="text">Account %(account)s not found.</field>
        </record>
        <record model="ir.message" id="party_required_for_account">
            <field name="text">Account "%(account)s" requires a party but no party was supplied in move "%(move)s".</field>
        </record>
        <record model="ir.message" id="msg_invalid_invoice_type">
            <field name="text">Invoice type must be 'out' or 'in' but "%(type)s" was found.</field>
        </record>
        <record model="ir.message" id="msg_company_not_found">
            <field name="text">Company %(company)s not found.</field>
        </record>
        <record model="ir.message" id="party_not_found">
            <field name="text">Party "%(party)s" not found.</field>
        </record>
        <record model="ir.message" id="msg_subdivision_not_found">
            <field name="text">Subdivision "%(subdivision)s" not found in country "%(country)s".</field>
        </record>
        <record model="ir.message" id="msg_subdivision_type_not_allowed">
            <field name="text">Subdivision type "%(type)s" of subdivision "%(subdivision)s" not allowed.</field>
        </record>
        <record model="ir.message" id="value_not_in_selection">
            <field name="text">Could not find this value in the field selection "%(field)%"</field>
        </record>
        <record model="ir.message" id="msg_sequence_type_required">
            <field name="text">Sequence Type is required</field>
        </record>
        <record model="ir.message" id="msg_sequence_type_not_found">
                <field name="text">Sequence Type "%(type)s" not found.</field>
        </record>
        <record model="ir.message" id="msg_group_not_found">
            <field name="text">Group with name "%(name)s" not found.</field>
        </record>
        <record model="ir.message" id="msg_role_not_found">
            <field name="text">Role with name "%(name)s" not found.</field>
        </record>
        <record model="ir.message" id="msg_deletes_disabled">
            <field name="text">Deletion of records is disabled.</field>
        </record>
    </data>

    <data depends="account">
        <record model="ir.message" id="msg_chart_not_found">
            <field name="text">Chart "%(chart)s" not found.</field>
        </record>
        <record model="ir.message" id="msg_asset_product_not_found">
            <field name="text">Asset product "%(product)s" does not exist on the database or it could not be found.</field>
        </record>
    </data>

    <data depends="bank">
        <record model="ir.message" id="wron_iban">
            <field name="text">Wrong IBAN %(iban)s.</field>
        </record>
        <record model="ir.message" id="bank_not_found">
            <field name="text">Bank not found for iban: %(iban)s.</field>
        </record>
    </data>

    <data depends="commission">
        <record model="ir.message" id="agent_not_found">
            <field name="text">Agent not found for Agent %(agent)s and plan %(plan)s.</field>
        </record>
    </data>

    <data depends="stock">
        <record model="ir.message" id="stock_move_error">
            <field name="text">Coud not create move, could not find some info: from_location: "%(from_location)s", to_location: "%(to_location)s", product: "%(product)s".</field>
        </record>
    </data>

    <data depends="stock_supply">
        <record model="ir.message" id="order_point_not_value">
            <field name="text">Order point not fount a value for Warehouse:  %(warehouse)s or Product %(product)s .</field>
        </record>
        <record model="ir.message" id="order_point_type_not_supported">
            <field name="text">Type %(type_)s not supported for orderpoint.</field>
        </record>
    </data>

    <data depends="farm">
        <record model="ir.message" id="animal_not_found">
            <field name="text">Animal %(animal)s not found.</field>
        </record>
        <record model="ir.message" id="farm_not_found">
            <field name="text">Farm %(farm)s not found.</field>
        </record>
        <record model="ir.message" id="location_not_found">
            <field name="text">Location %(location)s not found.</field>
        </record>
        <record model="ir.message" id="produced_animals_not_found">
            <field name="text">No produced animals found.</field>
        </record>
        <record model="ir.message" id="tag_not_found">
            <field name="text">Can't find tag "%(tag)s".</field>
        </record>
    </data>

    <data depends="company">
        <record model="ir.message" id="msg_name_required">
            <field name="text">Missing company name.</field>
        </record>
        <record model="ir.message" id="msg_currency_not_found">
            <field name="text">Currency %(currency)s not found.</field>
        </record>
        <record model="ir.message" id="msg_supervisor_not_found">
            <field name="text">Supervisor "%(supervisor)s" not found.</field>
        </record>
        <record model="ir.message" id="msg_employee_not_found">
            <field name="text">Employee %(employee)s not found.</field>
        </record>
    </data>
    <data depends="bank">
        <record model="ir.message" id="msg_bank_name_required">
            <field name="text">The bank name is required.</field>
        </record>
    </data>

    <data depends="product_attribute_strict">
        <record model="ir.message" id="msg_product_attribute_not_found">
            <field name="text">Attribute %(attribute)s for product of code %(code)s could not be found.</field>
        </record>
        <record model="ir.message" id="msg_product_attribute_set_not_found">
            <field name="text">Attribute set %(set)s for product of code %(code)s could not be found.</field>
        </record>
        <record model="ir.message" id="msg_product_attribute_selection_not_found">
            <field name="text">Attribute set %(set)s attribute %(attribute)s of type "Selection" has no selection option value %(selection)s.</field>
        </record>
        <record model="ir.message" id="msg_product_attribute_incorrect_cast">
            <field name="text">Value %(value)s is incorrect for attribute %(attribute)s expected type %(type)s, with product code %(code)s</field>
        </record>
    </data>

    <data depends="product_attribute_strict">
        <record model="ir.message" id="msg_carrier_product_not_found">
            <field name="text">Product code %(product)s not found.</field>
        </record>
        <record model="ir.message" id="msg_carrier_party_not_found">
            <field name="text">Party code %(party)s not found.</field>
        </record>
    </data>
    <data depends="account_payment_holidays">
        <record model="ir.message" id="msg_holidays_party_not_found">
            <field name="text">Party code %(party)s not found.</field>
        </record>
    </data>
</tryton>
